{
	"name": "illumi-family-mvp",
	"description": "A template for building a React application with Vite, Hono, and Cloudflare Workers",
	"cloudflare": {
		"label": "Vite React Template",
		"products": [
			"Workers"
		],
		"categories": [],
		"preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/532a5378-9717-4964-385b-5fafd2160200/public",
		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/ec7f4be5-d1d6-4e94-0851-126341745400/preview",
		"publish": true
	},
	"dependencies": {
		"@base-ui/react": "^1.2.0",
		"@cloudflare/stream-react": "^1.9.3",
		"@hono/zod-validator": "^0.7.6",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.163.3",
		"better-auth": "^1.5.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dayjs": "^1.11.20",
		"drizzle-orm": "^0.45.1",
		"hono": "4.11.1",
		"i18next": "^25.8.18",
		"lucide-react": "^0.576.0",
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"react-i18next": "^16.5.8",
		"resend": "^6.9.3",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "1.15.3",
		"@eslint/js": "9.39.1",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "24.10.1",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "5.1.1",
		"drizzle-kit": "^0.31.9",
		"eslint": "9.39.2",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "0.4.24",
		"globals": "16.5.0",
		"tailwindcss": "^4.2.1",
		"typescript": "5.8.3",
		"typescript-eslint": "8.48.0",
		"vite": "^6.0.0",
		"vitest": "^4.0.18",
		"wrangler": "4.56.0"
	},
	"private": true,
	"packageManager": "pnpm@10.10.0",
	"scripts": {
		"build": "tsc -b && vite build",
		"cf-typegen": "wrangler types",
		"check": "tsc && vite build && wrangler deploy --dry-run --config wrangler.json --env dev",
		"check:dev": "wrangler deploy --dry-run --config wrangler.json --env dev",
		"check:prod": "tsc && vite build && wrangler deploy --dry-run --config wrangler.json --env=\"\"",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "wrangler d1 migrations apply DB --env dev --remote",
		"db:migrate:dev": "wrangler d1 migrations apply DB --env dev --remote",
		"db:migrate:local": "wrangler d1 migrations apply DB --env dev --local",
		"db:migrate:prod": "wrangler d1 migrations apply DB --remote",
		"deploy": "wrangler deploy --config wrangler.json --env dev",
		"deploy:dev": "wrangler deploy --config wrangler.json --env dev",
		"deploy:prod": "wrangler deploy --config wrangler.json --env=\"\"",
		"dev": "CLOUDFLARE_ENV=dev vite",
		"dev:prod": "vite",
		"lint": "eslint .",
		"preview": "pnpm run build && vite preview",
		"test": "vitest run --config vitest.config.ts",
		"test:watch": "vitest --config vitest.config.ts",
		"template:new": "node tools/create-illumi-family-app/create.mjs",
		"template:sync": "node tools/create-illumi-family-app/sync-template.mjs",
		"template:doctor": "node tools/create-illumi-family-app/create.mjs --doctor"
	},
	"type": "module",
	"pnpm": {
		"patchedDependencies": {
			"@better-auth/kysely-adapter@1.5.3": "patches/@better-auth__kysely-adapter@1.5.3.patch"
		}
	}
}
